# ==============================================================================
# FEDORAFORGE AUTOMATION - FALLBACK ENVIRONMENT CONFIGURATION
# ==============================================================================
# This file provides defaults for standalone module execution (debugging).
# When run via deploy.sh, the Interactive Wizard generates environment/active.env
# which takes precedence over everything here.
# ==============================================================================

# --- System & Host Identifiers ---
export HOSTNAME="${HOSTNAME:-homelab-server}"
export TIMEZONE="${TIMEZONE:-UTC}"
export SYSTEM_UID="${SYSTEM_UID:-1000}"
export SYSTEM_GID="${SYSTEM_GID:-1000}"

# --- ZFS Storage Topology ---
# Override these with actual disks when running outside the wizard.
# The wizard auto-detects and sets these in active.env.
export FASTPOOL_DISK="${/dev/nvme0n1:-}"
export DATAPOOL_DISK="${/dev/sdb:-}"

# --- Network & VPN Parameters ---
export TAILSCALE_HOSTNAME="${TAILSCALE_HOSTNAME:-homelab-server}"
export TAILSCALE_TAILNET="${tailfb0549.ts.net}"

# --- SECRETS MANAGEMENT ---
# The wizard prompts for these; fill in manually for standalone runs.
export TAILSCALE_AUTH_KEY="${TAILSCALE_AUTH_KEY:-}"
export GITEA_DB_PASSWORD="${GITEA_DB_PASSWORD:-$(openssl rand -hex 12 2>/dev/null || echo changeme)}"
export DUPLICATI_PASSWORD="${DUPLICATI_PASSWORD:-changeme}"

# --- Base Application Paths ---
export CONFIG_BASE_DIR="${CONFIG_BASE_DIR:-/fastpool}"
export STORAGE_BASE_DIR="${STORAGE_BASE_DIR:-/datapool}"

# Auto-detect the interface that owns the default route.
export PRIMARY_INTERFACE="${PRIMARY_INTERFACE:-$(ip route show default 2>/dev/null | awk '/default/ { print $5; exit }')}"

# --- SNORT3 ---
export SNORT_INTERFACE="${SNORT_INTERFACE:-${PRIMARY_INTERFACE}}"
export SNORT_HOME_NET="${SNORT_HOME_NET:-192.168.1.0/24}"

# --- SAMBA SECRETS ---
export SAMBA_USER="${SAMBA_USER:-smbuser}"
export SAMBA_PASSWORD="${SAMBA_PASSWORD:-changeme}"

# --- SEARXNG SECRETS ---
export SEARXNG_SECRET_KEY="${SEARXNG_SECRET_KEY:-$(openssl rand -hex 16 2>/dev/null || echo changeme)}"

# --- Wolf Streaming Server Parameters ---
export WOLF_WEB_PORT="${WOLF_WEB_PORT:-8451}"
export WOLF_INTERNAL_PORT="${WOLF_INTERNAL_PORT:-47989}"
export WOLF_RDP_PORT="${WOLF_RDP_PORT:-3389}"
export WOLF_AUDIO_ENABLED="${WOLF_AUDIO_ENABLED:-1}"
export WOLF_HEVC_ENCODING="${WOLF_HEVC_ENCODING:-1}"

# --- Resource Allocation ---
export WOLF_CPU_LIMIT="${WOLF_CPU_LIMIT:-4}"
export WOLF_MEMORY_LIMIT="${WOLF_MEMORY_LIMIT:-8G}"
export WOLF_CPU_RESERVE="${WOLF_CPU_RESERVE:-2}"
export WOLF_MEMORY_RESERVE="${WOLF_MEMORY_RESERVE:-4G}"

# --- GPU Configuration (optional) ---
# Uncomment if using NVIDIA GPU
# export WOLF_GPU_RUNTIME="nvidia"
# export NVIDIA_VISIBLE_DEVICES="all"
